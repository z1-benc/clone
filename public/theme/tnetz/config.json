{
    "name": "tnetz",
    "description": "TNETZ Premium — Giao diện chuyên nghiệp, sáng/tối",
    "version": "1.0.0",
    "images": "",
    "configs": [{
        "label": "Nền",
        "placeholder": "URL ảnh nền (để trống = mặc định)",
        "field_name": "background_url",
        "field_type": "input"
    }, {
        "label": "Sidebar",
        "placeholder": "Chọn kiểu sidebar",
        "field_name": "theme_sidebar",
        "field_type": "select",
        "select_options": {
            "light": "Sáng",
            "dark": "Tối"
        },
        "default_value": "light"
    }, {
        "label": "Header",
        "placeholder": "Chọn kiểu header",
        "field_name": "theme_header",
        "field_type": "select",
        "select_options": {
            "light": "Sáng",
            "dark": "Tối"
        },
        "default_value": "dark"
    }, {
        "label": "Màu chủ đạo",
        "placeholder": "Chọn màu",
        "field_name": "theme_color",
        "field_type": "select",
        "select_options": {
            "default": "Xanh dương",
            "green": "Xanh lá",
            "black": "Đen",
            "darkblue": "Xanh đậm"
        },
        "default_value": "default"
    }, {
        "label": "HTML tùy chỉnh",
        "placeholder": "JS/HTML thêm vào footer",
        "field_name": "custom_html",
        "field_type": "textarea"
    }]
}
