{
  "dns": {
    "servers": [
      {
        "tag": "local",
        "address": "https://223.5.5.5/dns-query",
        "detour": "direct"
      },
      {
        "tag": "block",
        "address": "rcode://refused"
      }
    ],
    "rules": [
      {
        "rule_set": "category-ads-all",
        "server": "block"
      }
    ],
    "final": "local",
    "strategy": "ipv4_only",
    "disable_cache": false
  },
  "experimental": {
    "cache_file": {
      "enabled": true
    },
    "clash_api": {
      "default_mode": "proxy",
      "external_controller": "127.0.0.1:9090",
      "secret": ""
    }
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "auto_route": true,
      "domain_strategy": "prefer_ipv4",
      "stack": "system",
      "strict_route": true,
      "sniff": true,
      "sniff_override_destination": true,
      "inet4_address": "172.19.0.1/30",
      "inet6_address": "2001:470:f9da:fdfa::1/64",
      "mtu": 9000,
      "endpoint_independent_nat": true
    }
  ],
  "outbounds": [
    {
      "type": "selector",
      "tag": "auto_proxy",
      "outbounds": ["auto_test"]
    },
    {
      "type": "urltest",
      "tag": "auto_test",
      "outbounds": []
    },
    {
      "type": "dns",
      "tag": "dns-out"
    },
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "block",
      "tag": "block"
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "rules": [
      {
        "protocol": "dns",
        "outbound": "dns-out"
      },
      {
        "rule_set": "category-ads-all",
        "outbound": "block"
      },
      {
        "outbound": "auto_proxy"
      }
    ],
    "rule_set": [
      {
        "tag": "category-ads-all",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-category-ads-all.srs",
        "download_detour": "direct"
      }
    ]
  }
}